{
	"name": "flowfox",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n frontend,backend,ngrok -c blue,green,yellow \"vite\" \"npm run dev:backend\" \"npm run dev:ngrok\"",
		"dev:frontend": "vite",
		"dev:backend": "cd backend && npm run dev",
		"dev:ngrok": "ngrok http 4001",
		"dev:ngrok:docker": "docker-compose -f docker-compose.ngrok.yml up",
		"dev:ngrok:docker:detach": "docker-compose -f docker-compose.ngrok.yml up -d",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"docker:up": "docker-compose up -d",
		"docker:down": "docker-compose down",
		"docker:build": "docker-compose build --no-cache",
		"docker:logs": "docker-compose logs -f",
		"docker:restart": "docker-compose restart"
	},
	"dependencies": {
		"@clerk/clerk-react": "^5.60.1",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^7.3.8",
		"@mui/material": "^7.3.8",
		"@types/gapi": "^0.0.47",
		"@xyflow/react": "^12.10.0",
		"axios": "^1.13.6",
		"googleapis": "^171.4.0",
		"motion": "^12.34.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-google-drive-picker": "^1.2.2",
		"react-router-dom": "^7.13.0",
		"reactflow": "^11.11.4"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"concurrently": "^9.1.2",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"tailwindcss": "^4.1.18",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.48.0",
		"vite": "^7.3.1"
	}
}
